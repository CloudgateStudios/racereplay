generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Race {
  id     Int     @id @default(autoincrement())
  slug   String  @unique
  name   String
  events Event[]
}

model Event {
  id               Int              @id @default(autoincrement())
  race             Race             @relation(fields: [raceId], references: [id])
  raceId           Int
  year             Int
  type             EventType
  date             DateTime         @db.Date
  athletes         Athlete[]
  segments         Segment[]
  categoryResults  CategoryResult[]

  @@unique([raceId, year])
}

model Segment {
  id           Int              @id @default(autoincrement())
  event        Event            @relation(fields: [eventId], references: [id])
  eventId      Int
  name         String
  displayOrder Int
  isFinish     Boolean          @default(false)
  athletes     AthleteSegment[]
}

model Athlete {
  id           Int              @id @default(autoincrement())
  event        Event            @relation(fields: [eventId], references: [id])
  eventId      Int
  bib            String
  name           String
  normalizedName String?
  gender         String
  division     String
  country      String
  city         String?
  team         String?
  status       AthleteStatus
  finishTime   String?
  waveTime     String?
  overallRank  Int?
  genderRank   Int?
  divisionRank Int?
  segments     AthleteSegment[]

  @@unique([eventId, bib])
  @@index([normalizedName])
}

model AthleteSegment {
  id          Int      @id @default(autoincrement())
  athlete     Athlete  @relation(fields: [athleteId], references: [id])
  athleteId   Int
  segment     Segment  @relation(fields: [segmentId], references: [id])
  segmentId   Int
  timeSeconds Float?
  epochTime   Float?
  gained      Int?
  lost        Int?
  net         Int?

  @@unique([athleteId, segmentId])
}

model CategoryResult {
  id        Int    @id @default(autoincrement())
  event     Event  @relation(fields: [eventId], references: [id])
  eventId   Int
  category  String
  name      String
  total     Int

  @@unique([eventId, category, name])
}

enum EventType {
  TRIATHLON
  ROAD_RACE
}

enum AthleteStatus {
  FIN
  DNF
  DSQ
  DNS
}
